# Anthropic Claude API (for AI Assistant chat)
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Claude Code Runner (http://localhost:3456 by default via Vite proxy)
VITE_CLAUDE_RUNNER_URL=http://localhost:3456
VITE_CLAUDE_RUNNER_API_KEY=
# Absolute path for Claude Code to work in when executing tasks
VITE_CLAUDE_RUNNER_WORKING_DIR=G:/project/trello
